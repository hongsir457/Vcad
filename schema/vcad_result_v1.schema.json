{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vcad.dev/schema/vcad_result_v1.schema.json",
  "title": "VCAD Result v1",
  "type": "object",
  "required": ["version", "request_id", "success", "summary", "results", "errors"],
  "properties": {
    "version": { "const": "vcad_result_v1" },
    "request_id": { "type": "string" },
    "success": { "type": "boolean" },
    "summary": {
      "type": "object",
      "required": ["total", "succeeded", "failed"],
      "properties": {
        "total": { "type": "integer" },
        "succeeded": { "type": "integer" },
        "failed": { "type": "integer" }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command_id", "type", "success"],
        "properties": {
          "command_id": { "type": ["string", "null"] },
          "type": { "type": "string" },
          "success": { "type": "boolean" },
          "entities": {
            "type": "array",
            "items": { "$ref": "#/$defs/entity" }
          },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "error": { "$ref": "#/$defs/error" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "required": ["entity_type", "handle", "object_id"],
      "properties": {
        "dsl_id": { "type": ["string", "null"] },
        "entity_type": { "type": "string" },
        "handle": { "type": "string" },
        "object_id": { "type": "string" },
        "layer": { "type": ["string", "null"] }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "command_id": { "type": "string" }
      }
    }
  }
}
